@model IEnumerable<Lab5_InventarioEF_C12585.Models.Producto>
@{
    ViewData["Title"] = "Catálogo de Productos";
}

<h2>Catálogo de Productos</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Agregar Producto</a>

@if (!Model.Any())
{
    <p>No hay productos registrados.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Categoría</th>
                <th>Fecha de Ingreso</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Nombre</td>
                    <td>₡@p.Precio.ToString("N0")</td>
                    <td>@p.Categoria</td>
                    <td>@p.FechaIngreso.ToString("dd/MM/yyyy")</td>
                    <td>@(p.Activo ? "Activo" : "Inactivo")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}