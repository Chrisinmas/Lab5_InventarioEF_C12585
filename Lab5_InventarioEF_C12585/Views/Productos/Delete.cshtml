@model Lab5_InventarioEF_C12585.Models.Producto
@{
    ViewData["Title"] = "Eliminar Producto";
}

<h2>¿Desea eliminar este producto?</h2>
<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Nombre</dd>
    <dt class="col-sm-2">Precio</dt>
    <dd class="col-sm-10">₡@Model.Precio.ToString("N0")</dd>
    <dt class="col-sm-2">Categoría</dt>
    <dd class="col-sm-10">@Model.Categoria</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar eliminación</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>